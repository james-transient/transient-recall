PORT=8090
MCP_ROUTE=/mcp
MCP_SSE_ROUTE=/sse
MCP_SSE_MESSAGES_ROUTE=/messages
NODE_ENV=development

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tr

# Optional static edge token
MCP_EDGE_BEARER_TOKEN=

# Require injected auth context (headers) for all tool calls.
TR_AUTH_STRICT=false

# Deduplicate identical payloads within this many seconds (0 = disabled by default).
# Set to 600 for retry/accidental-duplicate protection.
TR_DEDUPE_WINDOW_SEC=0

# Trigger tr_status reminder_due when last checkpoint exceeds this age.
TR_STALE_CHECKPOINT_MINUTES=20

# Dev fallback identity (used when auth context isn't injected)
TR_DEFAULT_SUBJECT=local-dev-user
TR_DEFAULT_TENANT=public

# Optional commit-checkpoint helper defaults
TR_MCP_BASE_URL=http://localhost:8090
TR_PROJECT_DEFAULT=
TR_AUTO_CHECKPOINT_INTERVAL_SEC=180
TR_AUTO_CHECKPOINT_MODE=project
TR_POWER_MODE_INTERVAL_SEC=300
