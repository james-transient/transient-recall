# Docker Compose environment overrides.
# Copy to docker.env and customize. Load with: docker compose --env-file docker.env up -d

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tr
POSTGRES_PORT=5432

# TR API (host port mapping; container always listens on 8090)
TR_PORT=8090

# TR config (passed to container)
TR_DEPLOYMENT_MODE=local
TR_AUTH_STRICT=false
# Required when TR_DEPLOYMENT_MODE=staging or production:
# MCP_EDGE_BEARER_TOKEN=replace-with-strong-shared-token
TR_DEFAULT_SUBJECT=local-dev-user
TR_DEFAULT_TENANT=public
TR_DEDUPE_WINDOW_SEC=0
TR_STALE_CHECKPOINT_MINUTES=20
